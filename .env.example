# App
APP_ENV=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

# Database
DATABASE_URL=postgresql+asyncpg://polymarket:polymarket@localhost:5432/polymarket_bot
DATABASE_URL_SYNC=postgresql://polymarket:polymarket@localhost:5432/polymarket_bot

# Redis
REDIS_URL=redis://localhost:6379/0

# Polymarket (public reads need no key)
GAMMA_API_URL=https://gamma-api.polymarket.com
DATA_API_URL=https://data-api.polymarket.com
CLOB_API_URL=https://clob.polymarket.com
CHAIN_ID=137

# Trading (leave empty for paper-only mode)
POLYMARKET_PRIVATE_KEY=
POLYMARKET_FUNDER_ADDRESS=
POLYMARKET_SIGNATURE_TYPE=0

# Risk limits
BANKROLL_USD=1000
MAX_POSITION_PCT=0.05
MAX_TOTAL_EXPOSURE_PCT=0.30
KELLY_FRACTION=0.25
MIN_EDGE=0.03
MIN_CONFIDENCE=0.60
TRADING_MODE=paper

# Market filters (comma-separated tags to exclude)
EXCLUDED_TAGS=politics,crypto,geopolitics,elections
INCLUDED_TAGS=weather,sports,business,science
STRICT_MARKET_FILTER=false

# External APIs (optional for v1 ingestion)
NEWSAPI_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=polymarket-bot/0.1

# Ollama — use qwen3:8b on 12GB GPUs; qwen3:32b needs ~20GB+ VRAM
ENABLE_LLM=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b

# Scheduler
SYNC_MARKETS_INTERVAL_SEC=60
SNAPSHOT_BOOKS_INTERVAL_SEC=60
FEATURES_INTERVAL_SEC=300
TRADE_EVAL_INTERVAL_SEC=300
